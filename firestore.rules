rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      // Temporarily disabled identity check to fix "admin-restricted-operation" 
      // hardening will require Anonymous Auth to be enabled in Firebase Console
      return true;
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.login is string && data.login.size() <= 50;
      }
      allow read: if true;
      allow write: if isValidUser(incoming());
    }

    match /occurrences/{occurrenceId} {
      allow read, write, delete: if true;
    }

    match /auditLogs/{logId} {
      allow read, create: if true;
    }

    match /systemData/{docId} {
      allow read, write: if true;
    }

    match /operationalKpis/{kpiId} {
      function isValidKpi(data) {
        return data.area is string &&
               data.regional is string &&
               data.tsId is string &&
               data.values is map &&
               data.updatedAt is number;
      }
      allow read: if true;
      allow write: if isValidKpi(incoming());
    }

    match /notifications/{notifId} {
      function isValidNotif(data) {
        return data.recipientId is string &&
               data.senderId is string &&
               data.recordId is string &&
               data.isRead is bool &&
               data.timestamp is number &&
               data.recipientLogin is string &&
               data.senderName is string &&
               data.commentId is string &&
               data.text is string;
      }
      allow read: if true;
      allow write: if isValidNotif(incoming());
      allow delete: if true;
    }
  }
}
